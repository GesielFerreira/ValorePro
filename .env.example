# ==============================================================
# ValorePro — Variáveis de Ambiente
# ==============================================================
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite o .env.local no repositório.
# ==============================================================

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://postgres:senha@localhost:5432/valorepro?schema=public"

# ── Redis ─────────────────────────────────────────────────────
# Cache de resultados (TTL 30 min) e BullMQ queues
REDIS_URL="redis://localhost:6379"

# ── Autenticação (NextAuth) ───────────────────────────────────
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── SerpAPI (Varredura Web) ──────────────────────────────────
# Obter em: https://serpapi.com/dashboard
SERPAPI_KEY=""

# ── Mercado Livre API ─────────────────────────────────────────
# Criar app em: https://developers.mercadolivre.com.br
MERCADOLIVRE_APP_ID=""
MERCADOLIVRE_SECRET=""
MERCADOLIVRE_ACCESS_TOKEN=""

# ── Amazon Product Advertising API ────────────────────────────
# Registrar em: https://affiliate-program.amazon.com.br
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_PARTNER_TAG=""

# ── IA — Google Gemini ────────────────────────────────────────
# Obter em: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ── Reputação de Lojas ───────────────────────────────────────
# WHOIS API (opcional — RDAP é fallback grátis para .br)
# Obter em: https://whoisjson.com
WHOIS_API_KEY=""

# Google Places API (necessária para score Google)
# Ativar em: https://console.cloud.google.com/apis
GOOGLE_PLACES_API_KEY=""

# ── Pagamentos — Pagar.me ────────────────────────────────────
# Dashboard: https://dashboard.pagar.me
PAGARME_API_KEY=""
PAGARME_ENCRYPTION_KEY=""

# ── Notificações — Firebase FCM ──────────────────────────────
# Console: https://console.firebase.google.com
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ── Notificações — SendGrid ──────────────────────────────────
# Dashboard: https://app.sendgrid.com
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@valorepro.com.br"

# ── Configurações Gerais ─────────────────────────────────────
# CEP padrão para cálculo de frete quando o usuário não informar
DEFAULT_CEP="01001000"

# Nível de log: debug | info | warn | error
LOG_LEVEL="info"

# URL pública da aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"
